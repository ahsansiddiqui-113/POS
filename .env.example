# POS System Environment Configuration
# Copy this file to .env and update the values

# ============================================
# SECURITY
# ============================================
# Generate a strong secret key for JWT tokens
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-here-change-in-production-12345abcdef

# ============================================
# BACKEND SERVER
# ============================================
# Port the backend server will run on
PORT=3001

# Database file path (SQLite)
DATABASE_PATH=./data/pos.db

# Node environment (development or production)
NODE_ENV=development

# ============================================
# FRONTEND
# ============================================
# Backend URL that frontend will connect to
REACT_APP_BACKEND_URL=http://localhost:3001

# ============================================
# OPTIONAL SETTINGS
# ============================================
# Log level (info, warn, error, debug)
LOG_LEVEL=info

# Enable CORS debugging
DEBUG_CORS=false
