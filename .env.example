# Environment
NODE_ENV=development
PORT=3000

# JWT Secret
JWT_SECRET=your_super_secret_key_change_in_production

# Database
DATABASE_PATH=C:/Users/{User}/AppData/Local/POSApp/pos.db
DATABASE_BACKUP_PATH=~/Documents/POSBackups

# App
APP_VERSION=1.0.0
DEBUG=false

# Network (for multi-device setup)
NETWORK_RETRY_ATTEMPTS=3
NETWORK_RETRY_DELAY=1000
