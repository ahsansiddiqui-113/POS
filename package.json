{
  "name": "pos-inventory-system",
  "version": "1.0.0",
  "description": "Production-ready Desktop POS and Inventory Management System",
  "main": "./build/electron.js",
  "homepage": "./",
  "homepage-electron": "./",
  "author": "POS Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run backend-dev\" \"npm run react-dev\"",
    "backend-dev": "tsc --project tsconfig.backend.json && node dist/backend/index.js",
    "electron-dev": "wait-on http://localhost:3000 && wait-on http://localhost:3001 && electron .",
    "react-dev": "cross-env PORT=3000 react-scripts start",
    "build": "npm run build:react && npm run build:backend && npm run build:electron",
    "build:react": "react-scripts build",
    "build:backend": "tsc --project tsconfig.backend.json",
    "build:electron": "tsc --project tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^8.7.0",
    "bwip-js": "^4.8.0",
    "cors": "^2.8.5",
    "jimp": "^0.22.8",
    "dotenv": "^16.3.1",
    "exceljs": "^4.3.0",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.11.0",
    "react-router-dom": "^6.16.0",
    "recharts": "^2.10.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.6",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/better-sqlite3": "^7.6.7",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^18.18.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^18.2.26",
    "@types/react-dom": "^18.2.11",
    "@typescript-eslint/eslint-plugin": "^6.8.1",
    "@typescript-eslint/parser": "^6.8.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.1",
    "cross-env": "^10.1.0",
    "electron": "^25.9.0",
    "electron-builder": "^24.6.4",
    "electron-is-dev": "^2.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.31",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.3.5",
    "ts-jest": "^29.1.1",
    "typescript": "^4.9.5",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.pos.app",
    "productName": "POS System",
    "files": [
      "dist/**/*",
      "build/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
